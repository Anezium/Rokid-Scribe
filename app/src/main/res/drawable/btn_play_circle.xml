<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/phosphor_mid" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="@color/phosphor_divider" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="@color/phosphor_primary" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
</selector>
